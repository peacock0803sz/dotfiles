; vim:filetype=gitconfig

[include]
	path = ~/dotfiles/dot_config/git/.gitconfig.base

[core]
	editor = vim

[gpg]
	format = ssh
[commit]
	gpgsign = true
[gpg "ssh"]
  program = /run/current-system/sw/bin/ssh-keygen

[credential "https://github.com"]
	helper = 
	helper = !/etc/profiles/per-user/peacock/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/etc/profiles/per-user/peacock/bin/gh auth git-credential
